{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/orchestra/task.schema.json",
  "title": "Orchestra Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "objective",
    "owned_files",
    "forbidden_files",
    "allowed_commands",
    "acceptance_criteria",
    "dependencies",
    "branch",
    "worktree_path",
    "status",
    "review_notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^T-[0-9]{4}(-[a-z0-9-]+)?$"
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "background_context": {
      "type": "string"
    },
    "plan_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "owned_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "forbidden_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "allowed_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "check", "kind"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-[0-9]{2,}$"
          },
          "check": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["command", "file_exists", "manual"]
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^T-[0-9]{4}(-[a-z0-9-]+)?$"
      },
      "uniqueItems": true
    },
    "branch": {
      "type": "string",
      "pattern": "^task/T-[0-9]{4}(-[a-z0-9-]+)?$"
    },
    "worktree_path": {
      "type": "string",
      "pattern": "^\\.orch/worktrees/T-[0-9]{4}(-[a-z0-9-]+)?/?$"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "planned",
        "in_progress",
        "self_review",
        "critic_review",
        "integration_review",
        "ready_to_merge",
        "merged",
        "blocked",
        "abandoned"
      ]
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "result_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "review_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["author", "timestamp", "verdict", "body"],
        "properties": {
          "author": {
            "type": "string",
            "enum": [
              "gemini-critic",
              "codex-integrator",
              "claude-orchestrator"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "verdict": {
            "type": "string",
            "enum": ["approve", "request_changes", "reject", "note"]
          },
          "body": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
